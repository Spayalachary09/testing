              "readOnly": false
            },
            {
              "label": "Consent to Text Message Notifications",
              "type": "checkbox",
              "required": false,
              "error_message": "Unable to process consent selection.",
              "options": [
                "Yes"
              ],
              "readOnly": false
            }
          ]
        }
      ],
      "data_validation": [
        "At least one consent option should be selected if applicant wishes to receive notifications"
