    {
      "id": "STEP_4",
      "step": 4,
      "type": "Rule",
      "label": "Confirm Household Composition",
      "description": "If the applicant confirms that only Jane and Lily are in the household, the application process proceeds to the next step. If the applicant indicates any other household composition, the application process is ended and the applicant is notified that they are not eligible to proceed.",
      "Input Parameter": [
        "status",
        "message"
      ],
      "details": {
        "rules": [
          {
            "label": "Proceed if household is only Jane and Lily",
            "logic": "If the applicant confirms that the household members are only Jane and Lily, allow the application to proceed to the next step."
          },
          {
            "label": "End application if household composition differs",
            "logic": "If the applicant indicates any household composition other than only Jane and Lily, terminate the application process and display an ineligibility message."
          }
        ]
      },
      "step_number": 4,
      "node_id": "STEP_4",
      "actions": [
        {
          "ACTION_5": {
            "id": "ACTION_5",
            "name": "Evaluate Household Composition and Route",
            "implementation": "Checks if household is only Jane and Lily. If true, proceeds to STEP_5. If false, routes to STEP_16 (Not Eligible Notification).",
            "trigger": "Rule",
            "triggerCondition": "Household member validation complete.",
            "sequence": 1,
            "linkedWidgetIds": [
              "STEP_5",
              "STEP_16"
            ]
          }
        }
      ]
