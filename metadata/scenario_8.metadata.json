{
  "steps": [
    {
      "id": "STEP_1",
      "step": 1,
      "type": "Screen",
      "label": "Application Type and Contact Information",
      "description": "On this screen, you will begin your application by selecting the type of application you wish to submit and providing your contact information. Please choose whether you are starting a new application or recertifying an existing one. Enter your full name, select your preferred language, and provide your email address and phone number. This information will be used to contact you regarding your application status and updates.",
      "details": [
        {
          "label": "Application Details",
          "repeatable_section": false,
          "fields": [
            {
              "label": "Application Type",
              "type": "dropdown",
              "required": true,
              "error_message": "Please select an application type.",
              "options": [
                "New Application",
                "Recertification"
              ],
              "readOnly": false
            },
            {
              "label": "Full Name",
              "type": "text",
              "required": true,
              "error_message": "Full name is required.",
              "readOnly": false
            },
            {
              "label": "Preferred Language",
              "type": "dropdown",
              "required": true,
              "error_message": "Please select your preferred language.",
              "options": [
                "English",
                "Spanish"
              ],
              "readOnly": false
            },
            {
              "label": "Email Address",
              "type": "text",
              "required": true,
              "error_message": "Please enter a valid email address.",
              "readOnly": false
            },
            {
              "label": "Phone Number",
              "type": "phone",
              "required": true,
              "error_message": "Please enter a valid phone number.",
              "readOnly": false
            }
          ]
        }
      ],
      "data_validation": [
        "Email address must be in valid format",
        "Phone number must be in valid format",
        "Full name cannot be empty",
        "Application type must be selected"
      ],
      "buttons": [
        {
          "label": "Next",
          "actor": "Applicant",
          "description": "Proceed to consent to notifications.",
          "action_ids": [
            "ACTION_1"
          ]
        }
      ],
      "owner": "Applicant",
      "step_number": 1,
      "node_id": "STEP_1",
      "actions": [
        {
          "ACTION_1": {
            "id": "ACTION_1",
            "name": "Trigger Notification Consent Screen",
            "implementation": "Upon clicking 'Next', validate input and navigate to STEP_2 (Notification Consent).",
            "trigger": "Rule",
            "triggerCondition": "Applicant clicks 'Next' and all required fields are valid.",
            "sequence": 1,
            "linkedWidgetIds": [
              "STEP_2"
            ]
          }
        }
