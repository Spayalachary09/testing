  "automation": {
    "requestProcessing": {
      "metadataDetection": {
        "patterns": ["scenario_*.metadata.json", "metadata.json", "scenario_map.json", "pdm.json"],
        "defaultPath": "./metadata/",
        "autoSelect": true,
        "scenarioMapSupport": true,
        "pdmValidation": true
      },
      "intentRecognition": {
        "keywords": {
          "create": ["create", "generate", "build", "new"],
          "extend": ["extend", "add", "enhance", "modify"],
          "fix": ["fix", "resolve", "debug", "repair"],
          "optimize": ["optimize", "improve", "performance", "speed"]
        },
        "modeMapping": {
          "create": ["create-models", "build-screens", "build-flow", "create-rules", "create-batch"],
          "extend": ["extend-models", "extend-screens", "extend-flow", "extend-rules", "extend-batch"],
          "fix": ["analyze-defect", "surgical-fix", "verify-fix"],
          "optimize": ["optimize-performance", "optimize-jobs"]
        }
      },
      "taskGeneration": {
        "autoGenerateFromRequest": true,
        "includeDependencies": true,
        "estimateTimelines": true,
        "calculateProgress": true,
        "autoExecution": true
      }
    },
    "executionControl": {
      "continuousExecution": true,
      "autoProgression": true,
      "dependencyManagement": true,
